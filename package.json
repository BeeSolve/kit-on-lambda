{
  "name": "@beesolve/lambda-bun-sveltekit-adapter",
  "version": "0.2.1",
  "description": "A SvelteKit adapter for Bun on Lambda",
  "keywords": [
    "adapter",
    "svelte",
    "sveltekit",
    "bun",
    "aws",
    "lambda"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./adapter/index.d.ts",
      "import": "./adapter/index.js"
    },
    "./cdk": {
      "types": "./dist/cdk.d.ts",
      "import": "./dist/cdk.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "adapter",
    "dist"
  ],
  "scripts": {
    "prepublish": "bun run build.ts"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.49.2",
    "aws-cdk": "^2.1101.0",
    "aws-cdk-lib": "^2.234.1",
    "constructs": "^10.4.4"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.8",
    "bun-plugin-dts": "^0.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@beesolve/lambda-bun-runtime": "^1.6.1",
    "@beesolve/lambda-keep-active": "^1.2.0"
  }
}

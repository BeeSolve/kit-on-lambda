{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
  },
  "include": [
    "*.js",
    "adapter/files/**/*.js",
    "adapter/internal.d.ts",
    "cdk.ts",
    "build.ts",
  ],
}
